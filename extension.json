{
  "name": "URNames",
  "version": "2.0.0",
  "author": [
    "[https://www.wikiskripta.eu/w/User:Josmart Josef Martiňák]"
  ],
  "url": "https://github.com/wikiskripta/URNames",
  "descriptionmsg": "urnames-desc",
  "type": "other",
  "license-name": "MIT",
  "status": "stable",
  "requires": {
    "MediaWiki": ">= 1.45.0"
  },
  "manifest_version": 2,
  "AutoloadNamespaces": {
    "MediaWiki\\Extension\\URNames\\": "includes/"
  },
  "Hooks": {
    "MediaWikiServices": "MediaWiki\\Extension\\URNames\\Hooks::onMediaWikiServices"
  },
  "MessagesDirs": {
    "URNames": [
      "i18n"
    ]
  },
  "config": {
    "URNamesPages": {
      "value": [
        "Recentchanges",
        "Activeusers",
        "BlockList",
        "Listusers",
        "history"
      ]
    },
    "URNamesCacheTTL": {
      "value": 86400
    }
  }
}
